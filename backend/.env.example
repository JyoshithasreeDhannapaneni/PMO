# MySQL Database
DATABASE_URL="mysql://username:password@localhost:3306/pmo_tracker"

# Or use individual settings:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=pmo_tracker

# Server
PORT=3001
NODE_ENV=development

# CORS
FRONTEND_URL=http://localhost:3000

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@pmo-tracker.com

# Cron Jobs
ENABLE_CRON_JOBS=true
