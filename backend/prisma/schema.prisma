// Prisma Schema for Project Migration Tracking System
// MySQL Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Main Projects Table
model Project {
  id              String   @id @default(uuid()) @db.VarChar(36)
  name            String   @db.VarChar(255)
  customerName    String   @map("customer_name") @db.VarChar(255)
  projectManager  String   @map("project_manager") @db.VarChar(255)
  accountManager  String   @map("account_manager") @db.VarChar(255)
  planType        PlanType @default(SILVER) @map("plan_type")
  
  // Dates
  plannedStart    DateTime @map("planned_start")
  plannedEnd      DateTime @map("planned_end")
  actualStart     DateTime? @map("actual_start")
  actualEnd       DateTime? @map("actual_end")
  
  // Delay tracking (auto-calculated)
  delayDays       Int      @default(0) @map("delay_days")
  delayStatus     DelayStatus @default(NOT_DELAYED) @map("delay_status")
  
  // Project lifecycle
  phase           ProjectPhase @default(KICKOFF)
  status          ProjectStatus @default(ACTIVE)
  
  // Migration details
  migrationTypes  String?  @map("migration_types") @db.VarChar(255) // Comma-separated: CONTENT,EMAIL,MESSAGING
  sourcePlatform  String?  @map("source_platform") @db.VarChar(255)
  targetPlatform  String?  @map("target_platform") @db.VarChar(255)
  
  // Cost tracking
  estimatedCost   Decimal? @map("estimated_cost") @db.Decimal(12, 2)
  actualCost      Decimal? @map("actual_cost") @db.Decimal(12, 2)
  
  // Notes
  description     String?  @db.Text
  notes           String?  @db.Text
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  // Template reference
  templateId      String?  @map("template_id") @db.VarChar(36)
  
  // Relations
  phases          ProjectPhaseRecord[]
  caseStudy       CaseStudy?
  notifications   Notification[]
  tasks           ProjectTask[]
  template        MigrationTemplate? @relation(fields: [templateId], references: [id])
  risks           ProjectRisk[]
  teamMembers     ProjectTeamMember[]
  documents       ProjectDocument[]
  statusReports   ProjectStatusReport[]
  changeRequests  ChangeRequest[]
  
  @@index([templateId])
  @@map("projects")
}

// Project Phase Records for detailed tracking
model ProjectPhaseRecord {
  id           String       @id @default(uuid()) @db.VarChar(36)
  projectId    String       @map("project_id") @db.VarChar(36)
  phaseName    String       @map("phase_name") @db.VarChar(255)
  orderIndex   Int          @default(0) @map("order_index")
  plannedStart DateTime     @map("planned_start")
  plannedEnd   DateTime     @map("planned_end")
  actualStart  DateTime?    @map("actual_start")
  actualEnd    DateTime?    @map("actual_end")
  status       PhaseStatus  @default(PENDING)
  progress     Int          @default(0) // 0-100 percentage
  notes        String?      @db.Text
  
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks        ProjectTask[]
  
  @@index([projectId])
  @@map("project_phases")
}

// Migration Templates (Content, Email, Messaging)
model MigrationTemplate {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String   @db.VarChar(255) // "Content Migration Template"
  code        String   @unique @db.VarChar(50) // "CONTENT", "EMAIL", "MESSAGING"
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  phases      TemplatePhase[]
  projects    Project[]
  
  @@map("migration_templates")
}

// Template Phases (Phase 1: Initiation, Phase 2: Infrastructure Setup, etc.)
model TemplatePhase {
  id              String   @id @default(uuid()) @db.VarChar(36)
  templateId      String   @map("template_id") @db.VarChar(36)
  name            String   @db.VarChar(255) // "Phase 1: Initiation"
  orderIndex      Int      @map("order_index")
  defaultDuration Int      @default(7) @map("default_duration") // Default days for this phase
  description     String?  @db.Text
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  template        MigrationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tasks           TemplateTask[]
  
  @@index([templateId])
  @@map("template_phases")
}

// Template Tasks (Kick off call, Pre-requisites, Server Creation, etc.)
model TemplateTask {
  id              String   @id @default(uuid()) @db.VarChar(36)
  phaseId         String   @map("phase_id") @db.VarChar(36)
  name            String   @db.VarChar(255) // "Kick off call"
  orderIndex      Int      @map("order_index")
  defaultDuration Int      @default(1) @map("default_duration") // Default days
  description     String?  @db.Text
  isMilestone     Boolean  @default(false) @map("is_milestone")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  phase           TemplatePhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  
  @@index([phaseId])
  @@map("template_tasks")
}

// Project Tasks (actual tasks created from template for each project)
model ProjectTask {
  id              String     @id @default(uuid()) @db.VarChar(36)
  projectId       String     @map("project_id") @db.VarChar(36)
  phaseRecordId   String     @map("phase_record_id") @db.VarChar(36)
  name            String     @db.VarChar(255)
  orderIndex      Int        @map("order_index")
  status          TaskStatus @default(TODO)
  plannedStart    DateTime   @map("planned_start")
  plannedEnd      DateTime   @map("planned_end")
  actualStart     DateTime?  @map("actual_start")
  actualEnd       DateTime?  @map("actual_end")
  duration        Int        @default(1) // Days
  progress        Int        @default(0) // 0-100 percentage
  assignee        String?    @db.VarChar(255)
  isMilestone     Boolean    @default(false) @map("is_milestone")
  notes           String?    @db.Text
  priority        Priority   @default(MEDIUM)
  estimatedHours  Decimal?   @map("estimated_hours") @db.Decimal(6, 2)
  actualHours     Decimal?   @map("actual_hours") @db.Decimal(6, 2)
  
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  
  project         Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phaseRecord     ProjectPhaseRecord @relation(fields: [phaseRecordId], references: [id], onDelete: Cascade)
  
  // Task Dependencies
  dependsOn       TaskDependency[] @relation("DependentTask")
  dependedBy      TaskDependency[] @relation("PredecessorTask")
  
  @@index([projectId])
  @@index([phaseRecordId])
  @@map("project_tasks")
}

// Task Dependencies
model TaskDependency {
  id              String         @id @default(uuid()) @db.VarChar(36)
  taskId          String         @map("task_id") @db.VarChar(36)
  dependsOnTaskId String         @map("depends_on_task_id") @db.VarChar(36)
  dependencyType  DependencyType @default(FINISH_TO_START) @map("dependency_type")
  lagDays         Int            @default(0) @map("lag_days")
  
  createdAt       DateTime       @default(now()) @map("created_at")
  
  task            ProjectTask    @relation("DependentTask", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask   ProjectTask    @relation("PredecessorTask", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)
  
  @@unique([taskId, dependsOnTaskId])
  @@index([taskId])
  @@index([dependsOnTaskId])
  @@map("task_dependencies")
}

// Risk Register for project risk management
model ProjectRisk {
  id            String       @id @default(uuid()) @db.VarChar(36)
  projectId     String       @map("project_id") @db.VarChar(36)
  title         String       @db.VarChar(255)
  description   String?      @db.Text
  category      RiskCategory @default(TECHNICAL)
  probability   RiskLevel    @default(MEDIUM)
  impact        RiskLevel    @default(MEDIUM)
  status        RiskStatus   @default(OPEN)
  mitigation    String?      @db.Text
  contingency   String?      @db.Text
  owner         String?      @db.VarChar(255)
  dueDate       DateTime?    @map("due_date")
  resolvedAt    DateTime?    @map("resolved_at")
  
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@map("project_risks")
}

// Team Members assigned to projects
model ProjectTeamMember {
  id            String     @id @default(uuid()) @db.VarChar(36)
  projectId     String     @map("project_id") @db.VarChar(36)
  name          String     @db.VarChar(255)
  email         String     @db.VarChar(255)
  role          TeamRole   @default(TEAM_MEMBER)
  department    String?    @db.VarChar(255)
  allocation    Int        @default(100) // Percentage allocation to this project
  startDate     DateTime?  @map("start_date")
  endDate       DateTime?  @map("end_date")
  isActive      Boolean    @default(true) @map("is_active")
  
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  
  project       Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@map("project_team_members")
}

// Project Documents and Attachments
model ProjectDocument {
  id            String         @id @default(uuid()) @db.VarChar(36)
  projectId     String         @map("project_id") @db.VarChar(36)
  name          String         @db.VarChar(255)
  description   String?        @db.Text
  category      DocumentCategory @default(OTHER)
  fileUrl       String?        @map("file_url") @db.VarChar(500)
  fileSize      Int?           @map("file_size")
  mimeType      String?        @map("mime_type") @db.VarChar(100)
  version       String?        @db.VarChar(50)
  uploadedBy    String?        @map("uploaded_by") @db.VarChar(255)
  
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@map("project_documents")
}

// Project Status Reports (Weekly/Monthly)
model ProjectStatusReport {
  id                String       @id @default(uuid()) @db.VarChar(36)
  projectId         String       @map("project_id") @db.VarChar(36)
  reportDate        DateTime     @map("report_date")
  reportType        ReportType   @default(WEEKLY)
  overallStatus     HealthStatus @default(GREEN) @map("overall_status")
  scheduleStatus    HealthStatus @default(GREEN) @map("schedule_status")
  budgetStatus      HealthStatus @default(GREEN) @map("budget_status")
  resourceStatus    HealthStatus @default(GREEN) @map("resource_status")
  
  // Progress snapshot
  completionPercentage Int       @default(0) @map("completion_percentage")
  tasksCompleted    Int          @default(0) @map("tasks_completed")
  tasksTotal        Int          @default(0) @map("tasks_total")
  
  // Summary sections
  accomplishments   String?      @db.Text
  plannedActivities String?      @map("planned_activities") @db.Text
  issues            String?      @db.Text
  risks             String?      @db.Text
  decisions         String?      @db.Text
  
  // Budget snapshot
  budgetPlanned     Decimal?     @map("budget_planned") @db.Decimal(12, 2)
  budgetActual      Decimal?     @map("budget_actual") @db.Decimal(12, 2)
  
  createdBy         String?      @map("created_by") @db.VarChar(255)
  
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  
  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@map("project_status_reports")
}

// Change Requests for scope/budget/timeline changes
model ChangeRequest {
  id              String             @id @default(uuid()) @db.VarChar(36)
  projectId       String             @map("project_id") @db.VarChar(36)
  title           String             @db.VarChar(255)
  description     String             @db.Text
  changeType      ChangeType         @default(SCOPE)
  priority        Priority           @default(MEDIUM)
  status          ChangeRequestStatus @default(PENDING)
  impact          String?            @db.Text
  justification   String?            @db.Text
  
  // Approval workflow
  requestedBy     String             @map("requested_by") @db.VarChar(255)
  requestedDate   DateTime           @default(now()) @map("requested_date")
  reviewedBy      String?            @map("reviewed_by") @db.VarChar(255)
  reviewedDate    DateTime?          @map("reviewed_date")
  approvedBy      String?            @map("approved_by") @db.VarChar(255)
  approvedDate    DateTime?          @map("approved_date")
  
  // Impact details
  costImpact      Decimal?           @map("cost_impact") @db.Decimal(12, 2)
  scheduleImpact  Int?               @map("schedule_impact") // Days
  
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  
  project         Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@map("change_requests")
}

// Case Studies linked to completed projects
model CaseStudy {
  id          String          @id @default(uuid()) @db.VarChar(36)
  projectId   String          @unique @map("project_id") @db.VarChar(36)
  status      CaseStudyStatus @default(PENDING)
  title       String?         @db.VarChar(255)
  content     String?         @db.Text
  publishedAt DateTime?       @map("published_at")
  
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@map("case_studies")
}

// Notifications for alerts and reminders
model Notification {
  id          String             @id @default(uuid()) @db.VarChar(36)
  projectId   String?            @map("project_id") @db.VarChar(36)
  type        NotificationType
  title       String             @db.VarChar(255)
  message     String             @db.Text
  recipients  String             @db.Text  // JSON string of email addresses (MySQL doesn't support arrays)
  status      NotificationStatus @default(PENDING)
  sentAt      DateTime?          @map("sent_at")
  
  createdAt   DateTime           @default(now()) @map("created_at")
  
  project     Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  @@index([projectId])
  @@map("notifications")
}

// User accounts for authentication
model User {
  id            String    @id @default(uuid()) @db.VarChar(36)
  name          String    @db.VarChar(255)
  username      String    @unique @db.VarChar(100)
  email         String    @unique @db.VarChar(255)
  password      String    @db.VarChar(255)
  role          UserRole  @default(VIEWER)
  avatar        String?   @db.VarChar(500)
  department    String?   @db.VarChar(255)
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  
  // User preferences (JSON stored as text)
  preferences   String?   @db.Text
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  sessions      Session[]
  passwordResets PasswordReset[]
  auditLogs     AuditLog[]
  comments      Comment[]
  activities    Activity[]
  
  @@map("users")
}

// Password Reset Tokens
model PasswordReset {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  
  createdAt DateTime @default(now()) @map("created_at")
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("password_resets")
}

// Audit Log for tracking all changes
model AuditLog {
  id          String     @id @default(uuid()) @db.VarChar(36)
  userId      String?    @map("user_id") @db.VarChar(36)
  action      AuditAction
  entityType  String     @map("entity_type") @db.VarChar(50)
  entityId    String     @map("entity_id") @db.VarChar(36)
  entityName  String?    @map("entity_name") @db.VarChar(255)
  oldValues   String?    @map("old_values") @db.Text
  newValues   String?    @map("new_values") @db.Text
  ipAddress   String?    @map("ip_address") @db.VarChar(45)
  userAgent   String?    @map("user_agent") @db.VarChar(500)
  
  createdAt   DateTime   @default(now()) @map("created_at")
  
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// Comments for projects, tasks, risks, etc.
model Comment {
  id          String      @id @default(uuid()) @db.VarChar(36)
  userId      String      @map("user_id") @db.VarChar(36)
  entityType  String      @map("entity_type") @db.VarChar(50)
  entityId    String      @map("entity_id") @db.VarChar(36)
  content     String      @db.Text
  parentId    String?     @map("parent_id") @db.VarChar(36)
  isEdited    Boolean     @default(false) @map("is_edited")
  
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      Comment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]   @relation("CommentReplies")
  
  @@index([userId])
  @@index([entityType, entityId])
  @@index([parentId])
  @@map("comments")
}

// Activity Feed
model Activity {
  id          String       @id @default(uuid()) @db.VarChar(36)
  userId      String?      @map("user_id") @db.VarChar(36)
  type        ActivityType
  entityType  String       @map("entity_type") @db.VarChar(50)
  entityId    String       @map("entity_id") @db.VarChar(36)
  entityName  String?      @map("entity_name") @db.VarChar(255)
  description String       @db.Text
  metadata    String?      @db.Text
  
  createdAt   DateTime     @default(now()) @map("created_at")
  
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activities")
}

// File Storage for uploaded documents
model FileUpload {
  id          String   @id @default(uuid()) @db.VarChar(36)
  filename    String   @db.VarChar(255)
  originalName String  @map("original_name") @db.VarChar(255)
  mimeType    String   @map("mime_type") @db.VarChar(100)
  size        Int
  path        String   @db.VarChar(500)
  entityType  String?  @map("entity_type") @db.VarChar(50)
  entityId    String?  @map("entity_id") @db.VarChar(36)
  uploadedBy  String?  @map("uploaded_by") @db.VarChar(36)
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([entityType, entityId])
  @@map("file_uploads")
}

// User sessions for token management
model Session {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  
  createdAt DateTime @default(now()) @map("created_at")
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("sessions")
}

// Enums
enum PlanType {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum ProjectPhase {
  KICKOFF
  MIGRATION
  VALIDATION
  CLOSURE
  COMPLETED
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum DelayStatus {
  NOT_DELAYED
  AT_RISK
  DELAYED
}

enum PhaseStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum CaseStudyStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  PUBLISHED
}

enum NotificationType {
  DELAY_DETECTED
  PROJECT_COMPLETED
  CASE_STUDY_REMINDER
  PHASE_COMPLETED
  GENERAL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
  SKIPPED
}

// Risk Management Enums
enum RiskCategory {
  TECHNICAL
  SCHEDULE
  RESOURCE
  BUDGET
  SCOPE
  EXTERNAL
  ORGANIZATIONAL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  OPEN
  MITIGATING
  RESOLVED
  ACCEPTED
  CLOSED
}

// Team Role Enum
enum TeamRole {
  PROJECT_MANAGER
  TECHNICAL_LEAD
  DEVELOPER
  QA_ENGINEER
  BUSINESS_ANALYST
  ARCHITECT
  TEAM_MEMBER
  STAKEHOLDER
}

// Document Category Enum
enum DocumentCategory {
  SOW
  CONTRACT
  REQUIREMENTS
  DESIGN
  TECHNICAL
  MEETING_NOTES
  STATUS_REPORT
  SIGN_OFF
  OTHER
}

// Report Type Enum
enum ReportType {
  DAILY
  WEEKLY
  MONTHLY
  MILESTONE
  ADHOC
}

// Health Status Enum (RAG)
enum HealthStatus {
  GREEN
  YELLOW
  RED
}

// Change Request Enums
enum ChangeType {
  SCOPE
  SCHEDULE
  BUDGET
  RESOURCE
  TECHNICAL
}

enum ChangeRequestStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Audit Action Types
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  STATUS_CHANGE
  EXPORT
}

// Activity Types
enum ActivityType {
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_COMPLETED
  TASK_CREATED
  TASK_COMPLETED
  TASK_ASSIGNED
  COMMENT_ADDED
  DOCUMENT_UPLOADED
  RISK_IDENTIFIED
  RISK_RESOLVED
  TEAM_MEMBER_ADDED
  STATUS_REPORT_GENERATED
  CHANGE_REQUEST_SUBMITTED
  CHANGE_REQUEST_APPROVED
  MILESTONE_REACHED
}

// Task Dependency Types
enum DependencyType {
  FINISH_TO_START
  START_TO_START
  FINISH_TO_FINISH
  START_TO_FINISH
}
